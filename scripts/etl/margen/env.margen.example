# Config del ETL de margenes (cargar_margen.py). Copialo a .env.margen en la raiz
# del deploy y rellena las claves:
#   cp scripts/etl/margen/env.margen.example .env.margen && chmod 600 .env.margen
# OJO: claves con $ u otros simbolos -> comillas simples (se cargan parseando el .env).

# === DESTINO: produXdia (232) — donde se carga margen_final ===
TGT_HOST=localhost
TGT_PORT=5432
TGT_DB=produXdia
TGT_USER=postgres
TGT_PASSWORD='CAMBIA_ESTA_CLAVE'

# === ORIGEN: BD POS (192.168.35.217) — host comun, una BD por empresa ===
SRC_HOST=192.168.35.217
SRC_PORT=5432
SRC_PWD_MERCAMIO='CAMBIA'
SRC_PWD_MTODO='CAMBIA'
SRC_PWD_BOGOTA='CAMBIA'
