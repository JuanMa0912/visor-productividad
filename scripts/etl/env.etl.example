# Config UNICA de los ETLs (la usan AMBOS: sync-local-to-gcp.sh y
# scripts/etl/margen/cargar_margen.py). UN solo archivo .env.etl en la raiz del
# deploy. Copialo y rellena las claves:
#   cp scripts/etl/env.etl.example .env.etl  &&  chmod 600 .env.etl
# OJO: claves con $ u otros caracteres especiales -> COMILLAS SIMPLES.

# === produXdia LOCAL (232) ===
# Origen del sync local->GCP Y destino del ETL de margenes (margen_final).
DB_HOST_LOCAL=localhost
DB_PORT_LOCAL=5432
DB_NAME_LOCAL=produXdia
DB_USER_LOCAL=postgres
DB_PASSWORD_LOCAL='CAMBIA_ESTA_CLAVE'
# DB_SSL_LOCAL=disable        # opcional; default disable para localhost

# === Cloud SQL GCP ===  (solo lo usa el sync local->GCP)
DB_HOST_GCP=34.73.63.145
DB_PORT_GCP=5432
DB_NAME_GCP=produxdia
DB_USER_GCP=visor
DB_PASSWORD_GCP='CAMBIA_ESTA_CLAVE'
# DB_SSL_GCP=require          # opcional; default require para GCP

# === POS origen (192.168.35.217) ===  (solo lo usa el ETL de margenes)
# Son las mismas BD que el app usa en EXCEL_DIAN_* (mercamio/mtodo/bogota).
DB_HOST_POS=192.168.35.217
DB_PORT_POS=5432
DB_PWD_POS_MERCAMIO='CAMBIA'
DB_PWD_POS_MTODO='CAMBIA'
DB_PWD_POS_BOGOTA='CAMBIA'
