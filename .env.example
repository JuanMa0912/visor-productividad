# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=produXdia
DB_USER=postgres
DB_PASSWORD=change-me
DB_SCHEMA=public
DB_SSL=false

# Session and audit security
# SESSION_COOKIE_SECURE: si la cookie de sesion debe llevar el flag `Secure`
# (solo HTTPS). En produccion NODE_ENV=production defaultea a true. PERO si
# el server esta sirviendo por HTTP plano (sin HTTPS), el browser rechaza
# las cookies Secure y el login entra en loop. Para esos casos: dejar en
# false hasta que haya HTTPS real, luego cambiar a true (o quitar la linea).
SESSION_COOKIE_SECURE=false
AUDIT_IP_HMAC_SECRET=replace-with-a-random-secret
TRUST_PROXY=false

# Runtime and cache
PRODUCTIVITY_CACHE_PATH=data/productivity-cache.json
# Si es "true", GET /api/productivity puede responder desde el JSON en disco sin consultar BD (más rápido pero puede quedar desactualizado).
# PRODUCTIVITY_SERVE_FILE_CACHE=false
NEXT_ENABLE_REACT_COMPILER=false
UPGRADE_INSECURE_REQUESTS=true
ALLOWED_DEV_ORIGINS=192.168.80.173
# Legacy/compat: el CSP actual en next.config.ts ya incluye 'unsafe-eval'.
# Esta variable no controla el CSP actual.
CSP_UNSAFE_EVAL=false
# COOP_DISABLED: pone Cross-Origin-Opener-Policy=unsafe-none cuando la app
# se sirve por HTTP plano (sin HTTPS). El navegador ignora COOP en HTTP y
# tira un warning en consola; con esto el warning desaparece. Una vez que
# haya HTTPS, dejar en false (o quitarlo) para recuperar la proteccion.
COOP_DISABLED=false
# La UI usa v2 solo cuando el valor es exactamente "1".
NEXT_PUBLIC_VENTAS_X_ITEM_USE_V2=0

# Build wrappers (scripts/build.mjs)
# NEXT_BUILD_MEMORY_MB=4096
# NEXT_BUILD_LOG_LIMITS=1
# NEXT_BUILD_STRICT=1

# Excel DIAN — una conexion PostgreSQL por empresa (mismo esquema de consulta).
# Configurar los valores reales solo en el entorno del servidor o .env.local.
# Comercializadora (mtodo)
EXCEL_DIAN_MTDO_DB_HOST=change-me
EXCEL_DIAN_MTDO_DB_PORT=5432
EXCEL_DIAN_MTDO_DB_NAME=change-me
EXCEL_DIAN_MTDO_DB_USER=change-me
EXCEL_DIAN_MTDO_DB_PASSWORD=change-me
EXCEL_DIAN_MTDO_DB_SCHEMA=public

# Mercamio (mio)
EXCEL_DIAN_MIO_DB_HOST=change-me
EXCEL_DIAN_MIO_DB_PORT=5432
EXCEL_DIAN_MIO_DB_NAME=change-me
EXCEL_DIAN_MIO_DB_USER=change-me
EXCEL_DIAN_MIO_DB_PASSWORD=change-me
EXCEL_DIAN_MIO_DB_SCHEMA=public

# Merkmios (bgt)
EXCEL_DIAN_BGT_DB_HOST=change-me
EXCEL_DIAN_BGT_DB_PORT=5432
EXCEL_DIAN_BGT_DB_NAME=change-me
EXCEL_DIAN_BGT_DB_USER=change-me
EXCEL_DIAN_BGT_DB_PASSWORD=change-me
EXCEL_DIAN_BGT_DB_SCHEMA=public

# Si es "true", "1" o "yes": /ExcelDian y GET /api/excel-dian/export no requieren sesion.
# Ponlo en .env.local (este archivo .env.example no lo carga Next). Reinicia `npm run dev`.
# Solo en redes confiables: expone descarga y carga a las Bases DIAN configuradas sin autenticacion.
# EXCEL_DIAN_EXPORT_PUBLIC=false
# Alternativa si el proxy no lee la variable anterior (Edge): queda expuesta al bundle del cliente.
# NEXT_PUBLIC_EXCEL_DIAN_EXPORT_PUBLIC=false

# Optional bootstrap admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Aviso de migración de acceso al portal (SOLO build local: npm run build && npm start).
# Variable de servidor (no NEXT_PUBLIC). NUNCA definir en GCP.
# LOCAL_PORTAL_MIGRATION_NOTICE=true

# Correo diario rotación (scripts/rotacion-daily-email.mts)
# Mercamio (Zimbra): SMTP 3465 · IMAP 3993 (solo lectura; el envío usa SMTP)
# SMTP_HOST=smtp.mercamio.com
# SMTP_PORT=3465
# SMTP_USER=notificaciones.uaid@mercamio.com
# SMTP_PASSWORD=change-me
# SMTP_FROM=Notificaciones UAID <notificaciones.uaid@mercamio.com>
# SMTP_TLS_REJECT_UNAUTHORIZED=false
# SMTP_SECURE=true
# SMTP_REQUIRE_TLS=false
# ROTACION_EMAIL_FLORESTA_TO=encargado@example.com,alexander@mercamio.com
# ROTACION_EMAIL_DRY_RUN=true

# Cronograma (Notion)
# Token de la integración interna creada en https://www.notion.so/my-integrations.
# Debe tener acceso (Connections) a la página que contiene el cronograma.
NOTION_TOKEN=ntn_replace-me
# ID de la página de Notion que contiene los bloques/databases del cronograma.
# Se toma de la URL: https://www.notion.so/<slug>-<ID>. Acepta con o sin guiones.
NOTION_CRONOGRAMA_PAGE_ID=00e49a2ceb6b83f58fc1010dd253ae67
